<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Detecção dos apps de motorista sem QUERY_ALL_PACKAGES: o sistema
         só revela a este app os pacotes explicitamente listados aqui. -->
    <queries>
        <package android:name="com.ubercab.driver" />
        <package android:name="com.ubercab.driver.debug" />
        <package android:name="com.taxis99.driver" />
        <package android:name="com.taxis99" />
        <package android:name="br.com.taxis99.driver" />
        <package android:name="sinet.startup.inDriver" />
    </queries>

    <application
        android:name=".NexusDriveApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexusDrive"
        tools:targetApi="35">

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.NexusDrive">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:label="@string/onboarding_title"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:label="@string/login_title"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.debug.DebugActivity"
            android:exported="false"
            android:label="Debug"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.license.LicenseGateActivity"
            android:exported="false"
            android:label="@string/license_title"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.admin.AdminPinActivity"
            android:exported="false"
            android:label="@string/admin_pin_title"
            android:theme="@style/Theme.NexusDrive" />

        <activity
            android:name=".ui.admin.AdminActivity"
            android:exported="false"
            android:label="@string/admin_title"
            android:theme="@style/Theme.NexusDrive" />

        <!-- Serviço de Acessibilidade: lê eventos dos apps de motorista (Uber/99) -->
        <service
            android:name=".service.DriverMonitorService"
            android:exported="false"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <receiver
            android:name=".service.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
